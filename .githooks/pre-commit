#!/usr/bin/env bash
# Pre-commit dispatcher (created by install-pii-guards.sh).
# Add other pre-commit checks above the operator-pii block.
set -e

ROOT="$(git rev-parse --show-toplevel)"

# Rule 0.9 -- customer-facing strings must come from the per-repo catalogue,
# not inline literals. Locked 2026-05-19. The script is a no-op in repos
# without a recognised catalogue marker, so it's safe to install everywhere.
if [ -x "$ROOT/.githooks/check-rule-09-strings.sh" ]; then
    "$ROOT/.githooks/check-rule-09-strings.sh" pre-commit || exit $?
fi

# Hardcoded-assistant-name guard -- the customer chooses the assistant's
# name at install time. Customer-rendered surfaces must NOT contain the
# literal word "Marvin". Locked 2026-05-19 after the THIRD scrub attempt.
# Complementary to Rule 0.9: Rule 0.9 catches inline literals; this hook
# catches the brand-noun specifically, including inside catalogue values.
# Per-line bypass: append `assistant-name-exempt`.
if [ -x "$ROOT/.githooks/check-assistant-name-hardcoded.sh" ]; then
    "$ROOT/.githooks/check-assistant-name-hardcoded.sh" pre-commit || exit $?
fi

"$ROOT/.githooks/pre-commit-operator-pii" || exit $?
