# CM052 PWG AI Conversation Ingest – environment overrides
# Copy to .env and fill in your values.

# Hub session directory (ZeroClaw workspace). Defaults to ~/.zeroclaw/workspace/sessions/
# CM052_USER_HUB_DIR=~/.zeroclaw/workspace/sessions/

# User identity. No default; required for unifier output. Fail-fast if unset.
CM052_USER_EMAIL=user@example.com

# Assistant display name (for UI labelling and routing to the user's local assistant). Defaults to "Assistant".
# CM052_ASSISTANT_NAME=Assistant

# CM048 endpoint for fact extraction wire.
# CM052_CM048_ENDPOINT=http://localhost:8089/api/v1/conversation/process

# Backfill policy (set per first-run prompt or install flag)
# CM052_BACKFILL_DAYS=30
# CM052_BACKFILL=all
