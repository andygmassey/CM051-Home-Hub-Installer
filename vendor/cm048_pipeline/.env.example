# CM048 Conversation Processing — environment overrides
# Copy to .env and fill in your values.
# These override defaults in settings.yaml.

OSTLER_USER_ID=your_user_id
OSTLER_USER_DISPLAY_NAME=Your Name
OSTLER_OLLAMA_URL=http://localhost:11434
OSTLER_QDRANT_URL=http://localhost:6333
OSTLER_OXIGRAPH_URL=http://localhost:7878
# OSTLER_PROCESSING_DIR=~/.ostler/processing
# Legacy back-compat: OSTLER_STATE_DIR / PWG_PROCESSING_DIR are still
# honoured (lower precedence than OSTLER_PROCESSING_DIR).
