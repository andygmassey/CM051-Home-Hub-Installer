+def api_subscription_receipt(payload):
+    """Accept a StoreKit receipt push from the iOS Companion (G1).
+
+    Payload shape (from CM031's SubscriptionService): ``{"receipt_b64":
+    "<base64 receipt>", "expires_at": "<ISO-8601 datetime>"}``.
