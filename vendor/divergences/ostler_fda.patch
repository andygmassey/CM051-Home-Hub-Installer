+        help="Extract but do not write the JSON output file.",
+    )
+    args = parser.parse_args(argv)
+
+    result: dict = {
+        "notes": 0,
+        "total_words": 0,
+        "notebooks": 0,
+        "errors": [],
+        "status": "ok",
