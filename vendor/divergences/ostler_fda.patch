+        if len(digits) < 4:
+            return "Phone contact"
+        prefix = ("+" + digits[:2]) if handle.startswith("+") else digits[:2]
+        return f"{prefix} … {digits[-2:]}"
+    local, _, domain = handle.partition("@")
+    if not domain:
+        return handle[:1] + "…"
+    return f"{local[:1]}…@{domain}"
