 OSTLER_HOME="${OSTLER_HOME:-$HOME}"
 OSTLER_PYTHON="${OSTLER_PYTHON:-python3}"
-OSTLER_BACKFILL_DAYS="${OSTLER_BACKFILL_DAYS:-365}"
+OSTLER_BACKFILL_DAYS="${OSTLER_BACKFILL_DAYS:-1825}"
