# CardDAV contact source
CARDDAV_URL=https://contacts.icloud.com/{DSID}/carddavhome/card/
CARDDAV_USERNAME=
CARDDAV_PASSWORD=

# Storage services
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=people
OXIGRAPH_URL=http://localhost:7878

# Embedding
EMBED_OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_BATCH_SIZE=50

# WhatsApp bridge (optional)
WHATSAPP_SESSION_DB=

# State
STATE_FILE=./state.json

# Resolution
DEFAULT_COUNTRY_CODE=852
DEFAULT_PRIVACY_LEVEL=L2

# User
USER_ID=
